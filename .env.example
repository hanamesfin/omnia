# ─── Required — must be set before running ────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: one OpenRouter key can call models from all listed providers.
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Or configure providers individually.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Cloud Translation (optional — falls back to GOOGLE_API_KEY if empty)
GOOGLE_TRANSLATE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
QWEN_API_KEY=
QWEN_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
MISTRAL_API_KEY=
XAI_API_KEY=
CODE_LLAMA_API_KEY=
CODE_LLAMA_API_URL=

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-before-deploy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Social sign-in (optional) ────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# Use \n for private-key line breaks when stored on one line.
APPLE_OAUTH_PRIVATE_KEY=

# ─── Database (overridden by docker-compose.yml for container networking) ──────
DATABASE_URL=postgresql+asyncpg://omnia:omnia_dev@localhost:5432/omnia

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant (self-hosted, see docker-compose.yml) ─────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── LLM settings ─────────────────────────────────────────────────────────────
# Model used for generation (Agent Architect → Prompt Engineering Engine)
LLM_GENERATION_MODEL=gpt-4o
# Model used for cheap calls (extraction, summarization, evaluation judge)
LLM_FAST_MODEL=gpt-4o-mini
# Max tokens per LLM call
LLM_MAX_TOKENS=4096
# In Demo Mode, aggressive timeout before falling back to fixtures (seconds)
LLM_DEMO_TIMEOUT_SECONDS=4

# ─── Demo Mode (§11.2) ────────────────────────────────────────────────────────
# Set to "true" to replay cached fixtures on LLM timeout (for live demos)
DEMO_MODE=false

# ─── Budget / Rate control (§7.4) ─────────────────────────────────────────────
# Max tokens per user per day (soft fail with clear message at limit)
DAILY_TOKEN_BUDGET_PER_USER=100000

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
